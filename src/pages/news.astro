---
import MainLayout from '@/layouts/MainLayout.astro';
import PageHero from '@/components/PageHero.astro';
import SectionNews from '@/components/sections/SectionNews.astro';
import SectionCrossLinks from '@/components/SectionCrossLinks.astro';
import CtaBanner from '@/components/CtaBanner.astro';
---

<MainLayout
  title="Haflinger News, Fotos & Berichte | HWZSV"
  description="Aktuelle Haflinger News mit Berichten, Haflinger Pferde Bildern, Downloads und Newsletter der Haflinger Welt-Zucht- und Sportvereinigung."
  showNavbar={true}
>
  <PageHero
    title="News & Aktuelles"
    lead="Berichte, Fotos, Downloads und Newsletter: bleiben Sie informiert über Zucht, Sport und Verbandsarbeit in der Haflinger-Welt."
    accent="Aktuelles"
    breadcrumbItems={[{ label: 'Startseite', href: '/' }, { label: 'News' }]}
  />

  <SectionNews showCta={false} />
  <SectionCrossLinks excludePath="/news" />

  <CtaBanner
    title="Immer auf dem Laufenden"
    text="Abonnieren Sie unseren Newsletter für aktuelle Nachrichten, Ergebnisse und Termine."
    buttonLabel="Newsletter abonnieren"
    buttonHref="#news-newsletteranmeldung"
  />
</MainLayout>
