  },
  {
    country: 'Luxemburg',
    region: 'Europa',
    lat: 49.6116,
    lng: 6.1319,
    type: 'ordentlich',
    cityHint: 'Luxemburg',
  },
  {
    country: 'Niederlande',
    region: 'Europa',
    lat: 52.3676,
    lng: 4.9041,
    type: 'ordentlich',
    cityHint: 'Utrecht / Regionen',
  },
  {
