    region: 'Europa',
    lat: 48.2082,
    lng: 16.3738,
    type: 'ordentlich',
    cityHint: 'Tirol / Wien',
  },
  {
    country: 'Schweden',
    region: 'Europa',
    lat: 59.3293,
    lng: 18.0686,
    type: 'ordentlich',
    cityHint: 'Stockholm',
  },
  {
    country: 'Schweiz',
    region: 'Europa',
    lat: 46.948,
    lng: 7.4474,
    type: 'ordentlich',
    cityHint: 'Bern / Regionen',
  },
  {
    country: 'Slowakei',
    region: 'Europa',
    lat: 48.1486,
    lng: 17.1077,
    type: 'ordentlich',
