---
import MainLayout from '@/layouts/MainLayout.astro';
import PageHero from '@/components/PageHero.astro';
import SectionCrossLinks from '@/components/SectionCrossLinks.astro';
import CtaBanner from '@/components/CtaBanner.astro';

const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY ?? '';

const ordentlicheMitglieder = [
  'Australien',
  'Belgien',
  'Bulgarien',
  'Dänemark',
  'Deutschland',
  'Frankreich',
  'Großbritannien',
  'Italien',
  'Kanada',
  'Luxemburg',
  'Niederlande',
  'Österreich',
  'Schweden',
  'Schweiz',
  'Slowakei',
  'Slowenien',
  'Tschechische Republik',
  'Ungarn',
  'USA',
];

const ausserordentlicheMitglieder = ['Dänemark', 'Deutschland'];

const memberSpots = [
  {
    country: 'Australien',
    region: 'Ozeanien',
    lat: -25.2744,
    lng: 133.7751,
    type: 'ordentlich',
    cityHint: 'Sydney / Melbourne',
