      font-weight: 700;
      color: #52525b;
    }

    .member-progress-track {
      height: 8px;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.08);
      overflow: hidden;
    }

    .member-progress-fill {
      height: 100%;
      width: 0;
      background: linear-gradient(90deg, #86172c 0%, #b42340 100%);
      border-radius: inherit;
      transition: width 0.3s ease;
    }

    .member-map-canvas {
      position: relative;
      overflow: hidden;
      border-radius: 16px;
      min-height: 380px;
      background:
        radial-gradient(
          circle at 22% 18%,
          rgba(134, 23, 44, 0.16),
          transparent 42%
        ),
        radial-gradient(
          circle at 78% 72%,
          rgba(24, 24, 27, 0.14),
          transparent 34%
        ),
        linear-gradient(180deg, #dde8f1 0%, #edf3f8 48%, #f7fafc 100%);
      border: 1px solid rgba(24, 24, 27, 0.14);
      isolation: isolate;
    }

    .member-map-canvas::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      box-shadow:
        inset 0 0 0 1px rgba(255, 255, 255, 0.32),
        inset 0 -20px 40px rgba(15, 23, 42, 0.08);
      pointer-events: none;
      z-index: 2;
    }

    .member-google-map {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
    }

    .member-map-overlay-hint {
      position: absolute;
      left: 10px;
      top: 10px;
      margin: 0;
      padding: 7px 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.9);
      color: #334155;
      font-size: 0.73rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      z-index: 3;
      pointer-events: none;
    }

    @media (max-width: 520px) {
      .member-map-canvas {
