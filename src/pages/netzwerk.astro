---
import MainLayout from '@/layouts/MainLayout.astro';
import PageHero from '@/components/PageHero.astro';
import SectionNetzwerk from '@/components/sections/SectionNetzwerk.astro';
import SectionCrossLinks from '@/components/SectionCrossLinks.astro';
import CtaBanner from '@/components/CtaBanner.astro';
---

<MainLayout
  title="Haflinger Netzwerk weltweit | HWZSV"
  description="Internationales Haflinger Netzwerk mit Mitgliedsorganisationen, Sportorganisationen und Behörden - inklusive Partnern aus Südtirol, Österreich und Europa."
  showNavbar={true}
>
  <PageHero
    title="Internationales Netzwerk"
    lead="Mitgliedsorganisationen, Sportorganisationen und Behörden: die HWZSV verbindet die Haflinger-Welt über Ländergrenzen hinweg."
    accent="Weltweit vernetzt"
    breadcrumbItems={[
      { label: 'Startseite', href: '/' },
      { label: 'Netzwerk' },
    ]}
  />

  <SectionNetzwerk showCta={false} />
  <SectionCrossLinks excludePath="/netzwerk" />

  <CtaBanner
    title="Teil des Netzwerks werden?"
    text="Erfahren Sie, wie Ihr Verband oder Ihre Organisation Mitglied im internationalen Netzwerk werden kann."
    buttonLabel="Kontakt aufnehmen"
  />
</MainLayout>
