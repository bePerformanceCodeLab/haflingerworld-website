---
import MainLayout from '@/layouts/MainLayout.astro';
import PageHero from '@/components/PageHero.astro';
import SectionZucht from '@/components/sections/SectionZucht.astro';
import SectionCrossLinks from '@/components/SectionCrossLinks.astro';
import CtaBanner from '@/components/CtaBanner.astro';
---

<MainLayout
  title="Haflinger Zucht, Zuchtbuch & Züchter | HWZSV"
  description="Haflinger Zucht mit Richtlinien, Rassegrundsätzen, Haflinger Zuchtbuch, Hengsten und Programmen für Züchter und Pferdezucht-Verbände."
  showNavbar={true}
>
  <PageHero
    title="Zucht"
    lead="Rassegrundsätze, Richtlinien, Zuchtprogramme, Datenbanken und Hengste - die Grundlagen einer verantwortungsvollen Haflinger Zucht."
    accent="Zucht & Qualität"
    breadcrumbItems={[{ label: 'Startseite', href: '/' }, { label: 'Zucht' }]}
  />

  <SectionZucht showCta={false} />
  <SectionCrossLinks excludePath="/zucht" />

  <CtaBanner
    title="Fragen zur Zucht?"
    text="Die HWZSV unterstützt Sie bei Fragen zu Zuchtrichtlinien, Stammbucheintragung und Deckhengstsuche."
  />
</MainLayout>
