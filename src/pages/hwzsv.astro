---
import MainLayout from '@/layouts/MainLayout.astro';
import PageHero from '@/components/PageHero.astro';
import SectionHwzsv from '@/components/sections/SectionHwzsv.astro';
import SectionCrossLinks from '@/components/SectionCrossLinks.astro';
import CtaBanner from '@/components/CtaBanner.astro';
---

<MainLayout
  title="HWZSV: Haflinger Weltverband & Organisation"
  description="Die HWZSV ist die internationale Haflinger Organisation mit Satzungen, Zuständigkeiten, Gremien und Projekten - inklusive kompakter Statutenübersicht."
  showNavbar={true}
>
  <PageHero
    title="HWZSV"
    lead="Aufgaben, Satzungen, Zuständigkeiten und Gremien des internationalen Haflinger Weltverbands."
    accent="Über die Vereinigung"
    breadcrumbItems={[{ label: 'Startseite', href: '/' }, { label: 'HWZSV' }]}
  />

  <SectionHwzsv showCta={false} />
  <SectionCrossLinks excludePath="/hwzsv" />

  <CtaBanner
    title="Satzungen oder Verbandsfragen?"
    text="Wir informieren Sie gerne über Statuten, Zuständigkeiten und die Verbandsarbeit als internationaler Haflinger Zuchtverband und Sportpartner."
  />
</MainLayout>
