---
import MainLayout from '@/layouts/MainLayout.astro';
import PageHero from '@/components/PageHero.astro';
import InteractiveEventCalendar from '@/components/sections/InteractiveEventCalendar.astro';
import SectionCrossLinks from '@/components/SectionCrossLinks.astro';
import CtaBanner from '@/components/CtaBanner.astro';
---

<MainLayout
  title="Haflinger Events 2026 | Weltausstellung, Weltkongress, Zuchttermine"
  description="Alle Haflinger Events 2026 mit Fokus auf Weltausstellung und Weltkongress sowie ausgewählten Zucht- und Sportterminen aus dem internationalen Verbandsumfeld."
  showNavbar={true}
>
  <PageHero
    title="Events & Kalender"
    lead="Internationale Termine, Wettbewerbe und Meetings - alle Veranstaltungen der Haflinger-Welt im Überblick."
    accent="Veranstaltungen"
    breadcrumbItems={[
      { label: 'Startseite', href: '/' },
      { label: 'Events & Kalender' },
    ]}
  />

  <InteractiveEventCalendar />
  <SectionCrossLinks excludePath="/events" />

  <CtaBanner
    title="Eigene Veranstaltung eintragen?"
    text="Melden Sie Ihre Veranstaltung an und erreichen Sie die internationale Haflinger-Community."
    buttonLabel="Veranstaltung melden"
  />
</MainLayout>
