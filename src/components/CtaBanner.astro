---
interface Props {
  title?: string;
  text?: string;
  buttonLabel?: string;
  buttonHref?: string;
}

const {
  title = 'Fragen? Wir helfen gerne.',
  text = 'Kontaktieren Sie die HWZSV-Geschäftsstelle – wir sind für Sie da.',
  buttonLabel = 'Zum Kontakt',
  buttonHref = '#kontakt',
} = Astro.props;
---

<section class="relative bg-white border-t border-black/5" data-reveal="fade-up">
  <div class="site-container py-16 sm:py-20 w-full">
    <div class="cta-banner w-full">
    <h3>{title}</h3>
    <p>{text}</p>
    <a
      href={buttonHref}
      class="inline-flex items-center justify-center gap-2 min-h-[48px] px-8 py-3.5 bg-white text-gray-900 text-sm font-semibold rounded-xl transition-colors duration-200 hover:bg-accent hover:text-white group"
    >
      <span>{buttonLabel}</span>
      <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
  </div>
</section>
