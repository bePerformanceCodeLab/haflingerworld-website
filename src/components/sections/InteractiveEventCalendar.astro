---
import { eventCalendarData } from '@/data/events';

const sectionId = 'events-kalender';

const categories = [
  'Alle',
  ...new Set(eventCalendarData.map((event) => event.category)),
];

const datedEvents = eventCalendarData
  .filter((event) => Boolean(event.startDate))
  .sort((a, b) => (a.startDate ?? '').localeCompare(b.startDate ?? ''));
const undatedEvents = eventCalendarData.filter((event) => !event.startDate);
const featuredEvents = eventCalendarData.filter((event) => event.featured);

function formatDayPart(value?: string) {
  if (!value) return '--';
  const date = new Date(`${value}T00:00:00`);
  if (Number.isNaN(date.getTime())) return '--';
  return new Intl.DateTimeFormat('de-DE', { day: '2-digit' }).format(date);
}

function formatMonthPart(value?: string) {
  if (!value) return 'tba';
  const date = new Date(`${value}T00:00:00`);
  if (Number.isNaN(date.getTime())) return 'tba';
  return new Intl.DateTimeFormat('de-DE', { month: 'short' }).format(date);
}
---

<section
  id={sectionId}
  class="py-20 sm:py-24 bg-gray-50 border-t border-black/5"
>
  <div class="site-container calendar-site-container">
    <header class="mb-12 sm:mb-16" data-reveal="fade-up">
      <p
        class="text-[11px] font-bold tracking-[0.12em] uppercase text-accent mb-3"
      >
        Interaktiver Eventkalender
      </p>
      <h2
        class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 tracking-tight mb-5 text-balance"
      >
        Termine finden, filtern und planen
      </h2>
      <p class="text-lg text-gray-600 leading-relaxed max-w-3xl">
        Der Kalender verbindet Weltausstellung, Weltkongress, Zucht- und
        Sporttermine in einer interaktiven Ansicht.
      </p>
    </header>

    {
      featuredEvents.length > 0 && (
        <article class="mb-10 sm:mb-12" data-reveal="fade-up">
          <h3 class="text-[11px] font-bold tracking-[0.12em] uppercase text-accent mb-5">
            Highlights 2026
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {featuredEvents.map((event) => (
              <a href={event.link ?? '/events'} class="calendar-highlight-card">
                <p class="calendar-highlight-label">
                  {event.dateText ?? 'Highlight'}
                </p>
                <h4 class="calendar-highlight-title">{event.title}</h4>
                <p class="calendar-highlight-meta">{event.location}</p>
                <p class="calendar-highlight-text">{event.description}</p>
              </a>
            ))}
          </div>
        </article>
      )
    }

    <div class="calendar-app" data-event-calendar data-reveal="fade-up">
      <script
        type="application/json"
        data-calendar-json
        set:html={JSON.stringify(eventCalendarData)}
      />

      <div class="calendar-topbar" role="region" aria-label="Kalendersteuerung">
        <div class="calendar-search-wrap">
          <label class="calendar-search-label" for="calendar-search-input">
            Suche
          </label>
          <input
            id="calendar-search-input"
            type="search"
            class="calendar-search-input"
            placeholder="z.B. Weltkongress, Neumarkt, Sport"
            autocomplete="off"
            aria-describedby="calendar-help-text"
            data-calendar-search
          />
        </div>

        <div class="calendar-month-nav" aria-label="Monatsnavigation">
          <button
            type="button"
            class="month-btn"
            data-month-prev
            aria-label="Vorheriger Monat"
          >
            <span aria-hidden="true">&larr;</span>
          </button>
          <p class="month-label" data-month-label>Monat</p>
          <button
            type="button"
            class="month-btn"
            data-month-next
            aria-label="Naechster Monat"
          >
            <span aria-hidden="true">&rarr;</span>
          </button>
          <button type="button" class="month-today-btn" data-month-today
            >Heute</button
          >
        </div>
      </div>

      <p class="calendar-help" id="calendar-help-text">
        Tipp: Kategorie waehlen, Monat navigieren und einen Tag anklicken. Ein
        Punkt im Feld bedeutet: An diesem Tag findet mindestens ein Event statt.
      </p>

      <div
        class="calendar-filter-bar"
        role="group"
        aria-label="Kategorien filtern"
      >
        {
          categories.map((category) => (
            <button
              type="button"
              class={`calendar-filter-chip ${category === 'Alle' ? 'is-active' : ''}`}
              data-filter-category={category}
              aria-pressed={category === 'Alle' ? 'true' : 'false'}
            >
              <span>{category}</span>
              <span class="calendar-filter-count" data-filter-count={category}>
                0
              </span>
            </button>
          ))
        }
      </div>

      <div class="calendar-legend" aria-label="Statuslegende">
        <span class="calendar-legend-item">
          <span class="calendar-legend-dot confirmed" aria-hidden="true"></span>
          Bestaetigt
        </span>
        <span class="calendar-legend-item">
          <span class="calendar-legend-dot planned" aria-hidden="true"></span>
          Geplant
        </span>
        <span class="calendar-legend-item">
          <span class="calendar-legend-dot tba" aria-hidden="true"></span>
          Termin folgt
        </span>
      </div>

      <div
        class="calendar-view-toggle"
        role="group"
        aria-label="Ansicht wechseln"
      >
        <button
          type="button"
          class="calendar-view-btn is-active"
          data-view-target="calendar"
          aria-pressed="true"
        >
          Kalender
        </button>
        <button
          type="button"
          class="calendar-view-btn"
          data-view-target="list"
          aria-pressed="false"
        >
          Liste
        </button>
      </div>

      <div
        class="calendar-stats"
        data-calendar-stats
        role="status"
        aria-live="polite"
      >
        <p class="calendar-stat-item">
          <span class="calendar-stat-label">Treffer</span>
          <strong class="calendar-stat-value" data-stat-total
            >{eventCalendarData.length}</strong
          >
        </p>
        <p class="calendar-stat-item">
          <span class="calendar-stat-label">Im Monat</span>
          <strong class="calendar-stat-value" data-stat-month
            >{datedEvents.length}</strong
          >
        </p>
        <p class="calendar-stat-item">
          <span class="calendar-stat-label">Ohne Datum</span>
          <strong class="calendar-stat-value" data-stat-undated
            >{undatedEvents.length}</strong
          >
        </p>
      </div>

      <div class="calendar-pane" data-pane="calendar">
        <div class="calendar-weekdays" aria-hidden="true">
          <span>Mo</span>
          <span>Di</span>
          <span>Mi</span>
          <span>Do</span>
          <span>Fr</span>
          <span>Sa</span>
          <span>So</span>
        </div>
        <div
          class="calendar-grid"
          data-calendar-grid
          role="grid"
          aria-label="Monatskalender"
        >
        </div>

        <aside class="calendar-day-panel" data-day-panel>
          <p class="calendar-day-panel-label">Ausgewaehlter Tag</p>
          <h3 class="calendar-day-panel-title" data-day-title>Heute</h3>
          <ul class="calendar-day-list" data-day-list>
            <li class="calendar-day-empty">
              Waehle einen Tag aus dem Kalender.
            </li>
          </ul>
        </aside>
      </div>

      <div class="calendar-pane is-hidden" data-pane="list">
        <ul class="calendar-list" data-calendar-list>
          {
            datedEvents.slice(0, 6).map((event) => (
              <li class="calendar-list-card">
                <article class="calendar-list-item">
                  <div
                    class="calendar-list-date-badge"
                    aria-label={event.startDate}
                  >
                    <span class="calendar-list-day">
                      {formatDayPart(event.startDate)}
                    </span>
                    <span class="calendar-list-month">
                      {formatMonthPart(event.startDate)}
                    </span>
                  </div>
                  <div class="calendar-list-content">
                    <p class="calendar-list-top">
                      <span class="calendar-list-category">
                        {event.category}
                      </span>
                      <span class={`calendar-day-status ${event.status}`}>
                        {event.status === 'confirmed' && 'Bestaetigt'}
                        {event.status === 'planned' && 'Geplant'}
                        {event.status === 'tba' && 'Termin folgt'}
                      </span>
                    </p>
                    <h3 class="calendar-list-title">{event.title}</h3>
                    <p class="calendar-list-date-line">{event.startDate}</p>
                    <p class="calendar-list-meta">{event.location}</p>
                    <div class="calendar-list-divider" aria-hidden="true" />
                    <p class="calendar-list-text">{event.description}</p>
                  </div>
                </article>
              </li>
            ))
          }
        </ul>
      </div>

      <article class="calendar-undated" data-undated-block>
        <h3 class="calendar-undated-title">Termine ohne fixes Datum</h3>
        <ul class="calendar-undated-list" data-undated-list>
          {
            undatedEvents.map((event) => (
              <li class="calendar-undated-item">
                <div>
                  <p class="calendar-undated-date">
                    {event.dateText ?? 'Termin folgt'}
                  </p>
                  <p class="calendar-undated-event">{event.title}</p>
                  <p class="calendar-undated-meta">
                    {event.category} · {event.location}
                  </p>
                </div>
              </li>
            ))
          }
        </ul>
      </article>
    </div>
  </div>
</section>

<script is:inline>
  function initInteractiveCalendar() {
    const root = document.querySelector('[data-event-calendar]');
    if (!(root instanceof HTMLElement)) return;
    if (root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';

    try {
      const dataNode = root.querySelector('[data-calendar-json]');
      if (!(dataNode instanceof HTMLScriptElement)) return;

      const events = JSON.parse(dataNode.textContent || '[]').map((event) => {
        const start = parseDate(event.startDate);
        const end = parseDate(event.endDate || event.startDate);
        return {
          ...event,
          start,
          end,
        };
      });

      const searchInput = root.querySelector('[data-calendar-search]');
      const monthLabel = root.querySelector('[data-month-label]');
      const grid = root.querySelector('[data-calendar-grid]');
      const list = root.querySelector('[data-calendar-list]');
      const dayTitle = root.querySelector('[data-day-title]');
      const dayList = root.querySelector('[data-day-list]');
      const statTotal = root.querySelector('[data-stat-total]');
      const statMonth = root.querySelector('[data-stat-month]');
      const statUndated = root.querySelector('[data-stat-undated]');
      const filterButtons = Array.from(
        root.querySelectorAll('[data-filter-category]'),
      );
      const viewButtons = Array.from(
        root.querySelectorAll('[data-view-target]'),
      );
      const panes = Array.from(root.querySelectorAll('[data-pane]'));

      if (
        !(searchInput instanceof HTMLInputElement) ||
        !(monthLabel instanceof HTMLElement) ||
        !(grid instanceof HTMLElement) ||
        !(list instanceof HTMLElement) ||
        !(dayTitle instanceof HTMLElement) ||
        !(dayList instanceof HTMLElement) ||
        !(statTotal instanceof HTMLElement) ||
        !(statMonth instanceof HTMLElement) ||
        !(statUndated instanceof HTMLElement)
      ) {
        return;
      }

      const now = today();
      const nextUpcoming = events
        .filter((event) => event.start && event.start >= now)
        .sort((a, b) => a.start - b.start)[0];

      const state = {
        query: '',
        category: 'Alle',
        view: 'calendar',
        monthCursor: startOfMonth(nextUpcoming?.start || now),
        selectedDate: nextUpcoming?.start || now,
      };

      function normalize(value) {
        return String(value || '').toLowerCase();
      }

      function formatMonth(value) {
        return new Intl.DateTimeFormat('de-DE', {
          month: 'long',
          year: 'numeric',
        }).format(value);
      }

      function formatDate(value) {
        return new Intl.DateTimeFormat('de-DE', {
          day: '2-digit',
          month: '2-digit',
          year: 'numeric',
        }).format(value);
      }

      function dateKey(value) {
        return `${value.getFullYear()}-${String(value.getMonth() + 1).padStart(2, '0')}-${String(value.getDate()).padStart(2, '0')}`;
      }

      function dayDifference(start, end) {
        const msPerDay = 24 * 60 * 60 * 1000;
        return Math.round((end - start) / msPerDay) + 1;
      }

      function inDateRange(event, value) {
        if (!event.start || !event.end) return false;
        return value >= event.start && value <= event.end;
      }

      function getFilteredEvents() {
        const query = normalize(state.query);
        return events.filter((event) => {
          if (state.category !== 'Alle' && event.category !== state.category) {
            return false;
          }

          if (!query) return true;

          const haystack = normalize(
            [
              event.title,
              event.category,
              event.location,
              event.description,
              event.dateText,
            ].join(' '),
          );
          return haystack.includes(query);
        });
      }

      function getMonthEvents(filteredEvents) {
        const monthStart = startOfMonth(state.monthCursor);
        const monthEnd = endOfMonth(state.monthCursor);
        return filteredEvents.filter((event) => {
          if (!event.start || !event.end) return false;
          return event.start <= monthEnd && event.end >= monthStart;
        });
      }

      function updateFilterCounts() {
        const query = normalize(state.query);
        filterButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          const category = button.dataset.filterCategory || 'Alle';
          const countNode = button.querySelector('[data-filter-count]');
          if (!(countNode instanceof HTMLElement)) return;

          const count = events.filter((event) => {
            if (category !== 'Alle' && event.category !== category)
              return false;
            if (!query) return true;
            const text = normalize(
              [
                event.title,
                event.category,
                event.location,
                event.description,
              ].join(' '),
            );
            return text.includes(query);
          }).length;

          countNode.textContent = String(count);
        });
      }

      function renderGrid(monthEvents) {
        const monthStart = startOfMonth(state.monthCursor);
        const gridStart = startOfCalendarGrid(monthStart);
        const selectedKey = dateKey(state.selectedDate);
        const todayKey = dateKey(now);
        const monthCursorIndex = monthStart.getMonth();

        const cells = [];
        for (let index = 0; index < 42; index += 1) {
          const cellDate = addDays(gridStart, index);
          const key = dateKey(cellDate);
          const isCurrentMonth = cellDate.getMonth() === monthCursorIndex;
          const isToday = key === todayKey;
          const isSelected = key === selectedKey;
          const dayEvents = monthEvents
            .filter((event) => inDateRange(event, cellDate))
            .sort((a, b) => {
              const aTime = a.start
                ? a.start.getTime()
                : Number.MAX_SAFE_INTEGER;
              const bTime = b.start
                ? b.start.getTime()
                : Number.MAX_SAFE_INTEGER;
              return aTime - bTime;
            });
          const hasEvents = dayEvents.length > 0;
          const intensity = Math.min(dayEvents.length, 3);
          const dayLabel = hasEvents
            ? `${formatDate(cellDate)} - ${dayEvents.length} Termin${dayEvents.length === 1 ? '' : 'e'}`
            : formatDate(cellDate);

          cells.push(`
          <button
            type="button"
            class="calendar-day${isCurrentMonth ? '' : ' is-muted'}${isToday ? ' is-today' : ''}${isSelected ? ' is-selected' : ''}${hasEvents ? ` is-has-events event-level-${intensity}` : ''}"
            data-day-key="${key}"
            aria-label="${dayLabel}"
          >
            <span class="calendar-day-head">
              <span class="calendar-day-number-wrap">
                ${hasEvents ? '<span class="calendar-day-indicator" aria-hidden="true"></span>' : ''}
                <span class="calendar-day-number">${cellDate.getDate()}</span>
              </span>
            </span>
          </button>
        `);
        }

        grid.innerHTML = cells.join('');
      }

      function renderDayPanel(filteredEvents) {
        const selected = state.selectedDate;
        dayTitle.textContent = new Intl.DateTimeFormat('de-DE', {
          weekday: 'long',
          day: '2-digit',
          month: 'long',
        }).format(selected);

        const matches = filteredEvents
          .filter((event) => inDateRange(event, selected))
          .sort((a, b) => {
            const aTime = a.start ? a.start.getTime() : Number.MAX_SAFE_INTEGER;
            const bTime = b.start ? b.start.getTime() : Number.MAX_SAFE_INTEGER;
            return aTime - bTime;
          });

        if (matches.length === 0) {
          dayList.innerHTML =
            '<li class="calendar-day-empty">Keine Termine an diesem Tag.</li>';
          return;
        }

        dayList.innerHTML = matches
          .map((event) => {
            const rangeText = event.start
              ? `${formatDate(event.start)}${event.end && dateKey(event.end) !== dateKey(event.start) ? ` - ${formatDate(event.end)}` : ''}`
              : event.dateText || 'Termin folgt';
            const statusText = statusLabel(event.status);

            return `
            <li class="calendar-day-item">
              <p class="calendar-day-item-top">
                <span class="calendar-day-badge">${escapeHtml(event.category)}</span>
                <span class="calendar-day-status ${event.status}">${statusText}</span>
              </p>
              <h4 class="calendar-day-item-title">${escapeHtml(event.title)}</h4>
              <p class="calendar-day-item-meta">${escapeHtml(rangeText)} · ${escapeHtml(event.location)}</p>
              <p class="calendar-day-item-text">${escapeHtml(event.description)}</p>
            </li>
          `;
          })
          .join('');
      }

      function renderList(filteredEvents) {
        const sorted = filteredEvents.slice().sort((a, b) => {
          const aTime = a.start ? a.start.getTime() : Number.MAX_SAFE_INTEGER;
          const bTime = b.start ? b.start.getTime() : Number.MAX_SAFE_INTEGER;
          return aTime - bTime;
        });
        const upcomingIndex = sorted.findIndex(
          (event) => event.start && event.start >= now,
        );

        if (sorted.length === 0) {
          list.innerHTML =
            '<li class="calendar-list-empty">Keine Treffer. Bitte Suchbegriff oder Filter anpassen.</li>';
          return;
        }

        list.innerHTML = sorted
          .map((event, index) => {
            const dateText = event.start
              ? `${formatDate(event.start)}${event.end && dateKey(event.end) !== dateKey(event.start) ? ` - ${formatDate(event.end)}` : ''}`
              : event.dateText || 'Termin folgt';
            const days =
              event.start && event.end
                ? dayDifference(event.start, event.end)
                : 0;
            const isNextUpcoming =
              upcomingIndex >= 0 && index === upcomingIndex;
            const dayNumber = event.start
              ? new Intl.DateTimeFormat('de-DE', { day: '2-digit' }).format(
                  event.start,
                )
              : '--';
            const monthLabel = event.start
              ? new Intl.DateTimeFormat('de-DE', { month: 'short' }).format(
                  event.start,
                )
              : 'tba';
            const locationText = escapeHtml(event.location);
            const categoryText = escapeHtml(event.category);
            const linkHref =
              typeof event.link === 'string' ? escapeHtml(event.link) : '';

            return `
            <li class="calendar-list-card${isNextUpcoming ? ' is-next' : ''}">
              <article class="calendar-list-item">
                <div class="calendar-list-date-badge${event.start ? '' : ' is-undated'}" aria-label="${escapeHtml(dateText)}">
                  <span class="calendar-list-day">${escapeHtml(dayNumber)}</span>
                  <span class="calendar-list-month">${escapeHtml(monthLabel)}</span>
                </div>
                <div class="calendar-list-content">
                  <p class="calendar-list-top">
                    <span class="calendar-list-category">${categoryText}</span>
                    ${isNextUpcoming ? '<span class="calendar-list-next-label">Naechster Termin</span>' : ''}
                    <span class="calendar-day-status ${event.status}">${statusLabel(event.status)}</span>
                  </p>
                  <h3 class="calendar-list-title">${escapeHtml(event.title)}</h3>
                  <p class="calendar-list-date-line">${escapeHtml(dateText)}</p>
                  <p class="calendar-list-meta">${locationText}</p>
                  <div class="calendar-list-divider" aria-hidden="true"></div>
                  <p class="calendar-list-text">${escapeHtml(event.description)}</p>
                  <p class="calendar-list-foot">
                    ${days > 1 ? `<span class="calendar-list-duration">${days} Tage</span>` : ''}
                    ${linkHref ? `<a class="calendar-list-link" href="${linkHref}">Mehr erfahren</a>` : ''}
                  </p>
                </div>
              </article>
            </li>
          `;
          })
          .join('');
      }

      function updateStats(filteredEvents, monthEvents) {
        statTotal.textContent = String(filteredEvents.length);
        statMonth.textContent = String(monthEvents.length);
        statUndated.textContent = String(
          filteredEvents.filter((event) => !event.start).length,
        );
      }

      function setView(nextView) {
        state.view = nextView;
        viewButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          const active = button.dataset.viewTarget === nextView;
          button.classList.toggle('is-active', active);
          button.setAttribute('aria-pressed', String(active));
        });

        panes.forEach((pane) => {
          if (!(pane instanceof HTMLElement)) return;
          pane.classList.toggle('is-hidden', pane.dataset.pane !== nextView);
        });
      }

      function render() {
        const filteredEvents = getFilteredEvents();
        const monthEvents = getMonthEvents(filteredEvents);
        monthLabel.textContent = formatMonth(state.monthCursor);

        updateFilterCounts();
        renderGrid(monthEvents);
        renderDayPanel(filteredEvents);
        renderList(filteredEvents);
        updateStats(filteredEvents, monthEvents);

        filterButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          const active = button.dataset.filterCategory === state.category;
          button.classList.toggle('is-active', active);
          button.setAttribute('aria-pressed', String(active));
        });
      }

      root.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;

        const dayButton = target.closest('[data-day-key]');
        if (dayButton instanceof HTMLButtonElement) {
          const key = dayButton.dataset.dayKey;
          if (key) state.selectedDate = parseDate(key) || state.selectedDate;
          render();
          return;
        }

        const categoryButton = target.closest('[data-filter-category]');
        if (categoryButton instanceof HTMLButtonElement) {
          state.category = categoryButton.dataset.filterCategory || 'Alle';
          render();
          return;
        }

        const viewButton = target.closest('[data-view-target]');
        if (viewButton instanceof HTMLButtonElement) {
          const nextView = viewButton.dataset.viewTarget || 'calendar';
          setView(nextView);
        }
      });

      root.querySelector('[data-month-prev]')?.addEventListener('click', () => {
        state.monthCursor = addMonths(state.monthCursor, -1);
        render();
      });

      root.querySelector('[data-month-next]')?.addEventListener('click', () => {
        state.monthCursor = addMonths(state.monthCursor, 1);
        render();
      });

      root
        .querySelector('[data-month-today]')
        ?.addEventListener('click', () => {
          state.monthCursor = startOfMonth(today());
          state.selectedDate = today();
          render();
        });

      searchInput.addEventListener('input', () => {
        state.query = searchInput.value.trim();
        render();
      });

      setView('calendar');
      render();
    } catch (error) {
      root.dataset.initialized = 'false';
      console.error(
        '[HWZSV] Eventkalender konnte nicht initialisiert werden.',
        error,
      );
    }
  }

  function parseDate(value) {
    if (!value) return null;
    const [year, month, day] = String(value)
      .split('-')
      .map((part) => Number(part));
    if (!year || !month || !day) return null;
    return new Date(year, month - 1, day);
  }

  function today() {
    const current = new Date();
    current.setHours(0, 0, 0, 0);
    return current;
  }

  function startOfMonth(date) {
    return new Date(date.getFullYear(), date.getMonth(), 1);
  }

  function endOfMonth(date) {
    return new Date(
      date.getFullYear(),
      date.getMonth() + 1,
      0,
      23,
      59,
      59,
      999,
    );
  }

  function startOfCalendarGrid(date) {
    const first = startOfMonth(date);
    const day = (first.getDay() + 6) % 7;
    return addDays(first, -day);
  }

  function addDays(date, amount) {
    const next = new Date(date);
    next.setDate(next.getDate() + amount);
    return next;
  }

  function addMonths(date, amount) {
    return new Date(date.getFullYear(), date.getMonth() + amount, 1);
  }

  function statusLabel(status) {
    if (status === 'confirmed') return 'Bestaetigt';
    if (status === 'planned') return 'Geplant';
    return 'Termin folgt';
  }

  function escapeHtml(value) {
    return String(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initInteractiveCalendar, {
      once: true,
    });
  } else {
    initInteractiveCalendar();
  }
  document.addEventListener('astro:page-load', initInteractiveCalendar);
  document.addEventListener('astro:after-swap', initInteractiveCalendar);
  window.addEventListener('pageshow', initInteractiveCalendar);
</script>

