---
import { Image } from 'astro:assets';
import zuchtHeader from '@/images/headers/zucht-header.webp';
import zuchtRassegrundsaetze from '@/images/zucht/zucht-rassegrundsaetze.webp';
import zuchtRichtlinien from '@/images/zucht/zucht-richtlinien.webp';
import zuchtZuchtprogramme from '@/images/zucht/zucht-zuchtprogramme.webp';
import zuchtDatenbanken from '@/images/zucht/zucht-datenbanken.webp';
import zuchtHengste from '@/images/zucht/zucht-hengste.webp';

interface Props {
  showCta?: boolean;
}
const { showCta = true } = Astro.props;
const sectionId = 'zucht';
const subpages = [
  { id: 'rassegrundsaetze', title: 'Rassegrundsätze', lead: 'Ziele, Leitlinien und definierte Merkmale der Rasse.', placeholder: 'Detaillierte Inhalte zu diesem Bereich können hier ergänzt werden – Texte, Links zu Dokumenten und Datenbanken.' },
  { id: 'richtlinien', title: 'Richtlinien / Gesetze', lead: 'Regelwerke für Zucht, Haltung und Registrierung.', placeholder: 'Detaillierte Inhalte zu diesem Bereich können hier ergänzt werden – Texte, Links zu Dokumenten und Datenbanken.' },
  { id: 'zuchtprogramme', title: 'Zuchtprogramme', lead: 'Leistungs-, Gesundheits- und Selektionsprogramme.', placeholder: 'Detaillierte Inhalte zu diesem Bereich können hier ergänzt werden – Texte, Links zu Dokumenten und Datenbanken.' },
  { id: 'datenbanken', title: 'Datenbanken', lead: 'Abstammung, Zuchtwerte und Leistungsdaten.', placeholder: 'Detaillierte Inhalte zu diesem Bereich können hier ergänzt werden – Texte, Links zu Dokumenten und Datenbanken.' },
  { id: 'hengste', title: 'Hengste', lead: 'Zugelassene Hengste, Körungen und Prüfungen.', placeholder: 'Detaillierte Inhalte zu diesem Bereich können hier ergänzt werden – Texte, Links zu Dokumenten und Datenbanken.' },
];

const pillars = [
  { icon: 'shield', label: 'Gesundheit' },
  { icon: 'star', label: 'Leistung' },
  { icon: 'heart', label: 'Charakter' },
  { icon: 'eye', label: 'Exterieur' },
  { icon: 'globe', label: 'Vielfalt' },
];
---

<section id={sectionId} class="py-20 sm:py-24 bg-gray-50 border-t border-black/5 overflow-hidden">
  <div class="site-container">
    
    <!-- Section Header -->
    <header class="mb-12 sm:mb-16" data-reveal="fade-up">
      <p class="text-[11px] font-bold tracking-[0.12em] uppercase text-accent mb-3">
        Zucht
      </p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 tracking-tight mb-5 text-balance">
        Klare Leitlinien für eine starke Zukunft
      </h2>
      <p class="text-lg text-gray-600 leading-relaxed max-w-2xl">
        Zucht bedeutet Verantwortung. Die HWZSV schafft Strukturen, die Qualität sichern und die Vielfalt der Rasse bewahren.
      </p>
    </header>

    <!-- Header Image -->
    <div class="mb-16 sm:mb-20 rounded-2xl overflow-hidden" data-reveal="scale">
      <Image src={zuchtHeader} alt="Zucht – Klare Leitlinien für eine starke Zukunft" class="w-full h-auto object-cover aspect-[21/9]" width={1280} height={548} />
    </div>

    <!-- 5 Pillars of Breeding -->
    <div class="mb-16 sm:mb-20" data-reveal="fade-up">
      <p class="text-[11px] font-bold tracking-[0.12em] uppercase text-gray-400 mb-6">
        5 Säulen der Zucht
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3" data-reveal-stagger="60">
        {pillars.map((pillar) => (
          <div class="flex flex-col items-center gap-3 p-5 sm:p-6 bg-white border border-black/4 rounded-2xl text-center" data-reveal="scale">
            <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-accent/8 flex items-center justify-center text-accent">
              {pillar.icon === 'shield' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              )}
              {pillar.icon === 'star' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              )}
              {pillar.icon === 'heart' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              )}
              {pillar.icon === 'eye' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              )}
              {pillar.icon === 'globe' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              )}
            </div>
            <span class="text-sm font-semibold text-gray-700">{pillar.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Featured Card (first item full-width) -->
    <article id={`${sectionId}-${subpages[0].id}`} class="scroll-mt-28 mb-6 sm:mb-8" data-reveal="fade-up">
      <div class="zucht-card group h-full">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
          <div class="rounded-xl overflow-hidden aspect-video">
            <Image src={zuchtRassegrundsaetze} alt={subpages[0].title} class="w-full h-full object-cover" width={800} height={450} />
          </div>
          <div class="flex flex-col justify-center">
            <span class="text-[11px] font-bold tracking-[0.12em] uppercase text-accent">01</span>
            <h3 class="text-xl sm:text-2xl font-bold text-gray-900 mt-2 mb-4 leading-tight">{subpages[0].title}</h3>
            <p class="text-base text-gray-900 font-medium leading-relaxed mb-3">{subpages[0].lead}</p>
            <p class="placeholder-text">{subpages[0].placeholder}</p>
          </div>
        </div>
      </div>
    </article>

    <!-- Remaining Cards in 2-column grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" data-reveal-stagger="100">
      {[zuchtRichtlinien, zuchtZuchtprogramme, zuchtDatenbanken, zuchtHengste].map((image, index) => {
        const item = subpages[index + 1];
        return (
        <article id={`${sectionId}-${item.id}`} class="scroll-mt-28" data-reveal="fade-up">
          <div class="zucht-card group h-full">
            <div class="zucht-card-img mb-4 rounded-xl overflow-hidden aspect-video">
              <Image src={image} alt={item.title} class="w-full h-full object-cover" width={800} height={450} />
            </div>
            <div class="mb-4">
              <span class="text-[11px] font-bold tracking-[0.12em] uppercase text-accent">
                {String(index + 2).padStart(2, '0')}
              </span>
              <h3 class="text-xl sm:text-2xl font-bold text-gray-900 mt-2 leading-tight">
                {item.title}
              </h3>
            </div>
            <div class="flex-1">
              <p class="text-base text-gray-900 font-medium leading-relaxed mb-3">{item.lead}</p>
              <p class="placeholder-text">{item.placeholder}</p>
            </div>
          </div>
        </article>
        );
      })}
    </div>

    {showCta && (
      <div class="mt-16 sm:mt-20 pt-8 border-t border-black/5" data-reveal="fade-up">
        <a href="/zucht" class="inline-flex items-center justify-center gap-2 min-h-[48px] px-6 py-3 bg-gray-900 text-white text-sm font-semibold rounded-xl transition-all duration-200 hover:bg-accent hover:shadow-lg hover:shadow-accent/20 hover:-translate-y-0.5 sm:px-8 sm:py-3.5 group btn-glow">
          Zur Zucht-Seite
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    )}

  </div>
</section>

<style>
  .zucht-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.04);
    border-radius: 16px;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    min-height: 240px;
  }

  @media (min-width: 640px) {
    .zucht-card { padding: 28px; }
  }

  .zucht-card:hover {
    border-color: rgba(134, 23, 44, 0.12);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  @media (max-width: 767px) {
    .zucht-card { min-height: 200px; }
  }
</style>
