---
import { Image } from 'astro:assets';
import eventsHeader from '@/images/headers/events-header.webp';

interface Props {
  noTopBorder?: boolean;
  compactHeader?: boolean;
  showCta?: boolean;
}
const { noTopBorder = false, compactHeader = false, showCta = true } = Astro.props;
const sectionId = 'events';

const internationalEvents = [
  { 
    day: '12', month: 'APRIL', year: '2026',
    title: 'Internationales Haflinger Forum', 
    location: 'Bozen, Italien', 
    description: 'Strategiemeeting und Fachvorträge',
    link: '#'
  },
  { 
    day: '06', month: 'JUNI', year: '2026',
    title: 'Europacup Qualifikation', 
    location: 'Ebbs, Tirol', 
    description: 'Sportliche Sichtungen & Prüfungen',
    link: '#'
  },
  { 
    day: '21', month: 'AUGUST', year: '2026',
    title: 'Sommermeeting der Mitgliedsorganisationen', 
    location: 'Meran, Italien', 
    description: 'Austausch und Netzwerkpflege',
    link: '#'
  },
];

const nextEvent = internationalEvents[0];
---

<section id={sectionId} class={`py-20 sm:py-24 bg-gray-50 ${noTopBorder ? '' : 'border-t border-black/5'}`}>
  <div class="site-container">
    
    <!-- Section Header -->
    <header class={compactHeader ? 'mb-10 sm:mb-12' : 'mb-12 sm:mb-16'} data-reveal="fade-up">
      <p class="text-[11px] font-bold tracking-[0.12em] uppercase text-accent mb-3">
        Events & Kalender
      </p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 tracking-tight mb-5 text-balance">
        Kommende Termine
      </h2>
      <p class="text-lg text-gray-600 leading-relaxed max-w-2xl">
        Internationale Termine und Veranstaltungskalender – schnell auffindbar.
      </p>
    </header>

    {!compactHeader && (
      <div class="mb-16 sm:mb-20 rounded-2xl overflow-hidden" data-reveal="scale">
        <Image src={eventsHeader} alt="Events & Kalender – Kommende Termine" class="w-full h-auto object-cover aspect-[21/9]" width={1280} height={548} />
      </div>
    )}

    <!-- Next Event Countdown -->
    <div class="mb-12 sm:mb-16" data-reveal="fade-up">
      <div class="countdown-banner">
        <p class="text-[11px] font-bold tracking-[0.12em] uppercase text-accent/80 mb-2">Nächster Termin</p>
        <h3 class="text-xl sm:text-2xl font-bold text-gray-900 mb-2">{nextEvent.title}</h3>
        <p class="text-sm text-gray-500 mb-4">{nextEvent.day}. {nextEvent.month.charAt(0) + nextEvent.month.slice(1).toLowerCase()} {nextEvent.year} · {nextEvent.location}</p>
        <div class="countdown-grid" id="event-countdown">
          <div class="countdown-item">
            <span class="countdown-number" data-countdown-days>--</span>
            <span class="countdown-label">Tage</span>
          </div>
          <div class="countdown-item">
            <span class="countdown-number" data-countdown-hours>--</span>
            <span class="countdown-label">Stunden</span>
          </div>
          <div class="countdown-item">
            <span class="countdown-number" data-countdown-minutes>--</span>
            <span class="countdown-label">Minuten</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Internationale Termine -->
    <article id={`${sectionId}-internationale-termine`} class="scroll-mt-28 mb-12 sm:mb-16">
      <h3 class="text-[11px] font-bold tracking-[0.12em] uppercase text-accent mb-6" data-reveal="fade-up">
        Internationale Termine
      </h3>
      <p class="text-gray-600 leading-relaxed mb-8" data-reveal="fade-up">
        Termine der Mitgliedsorganisationen kompakt gesammelt.
      </p>

      <div class="space-y-6" data-reveal-stagger="100">
        {internationalEvents.map((event) => (
          <a href={event.link} class="event-card group" data-reveal="fade-left">
            <div class="event-indicator"></div>
            <div class="event-date">
              <div class="event-day">{event.day}</div>
              <div class="event-month">{event.month}</div>
              <div class="event-year">{event.year}</div>
            </div>
            <div class="event-content">
              <h4 class="event-title">{event.title}</h4>
              <div class="event-meta">
                <span class="event-location">{event.location}</span>
                <span class="event-separator">·</span>
                <span class="event-description">{event.description}</span>
              </div>
            </div>
            <div class="event-arrow">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </article>

    <!-- Veranstaltungskalender -->
    <article id={`${sectionId}-veranstaltungskalender`} class="scroll-mt-28" data-reveal="fade-up">
      <h3 class="text-[11px] font-bold tracking-[0.12em] uppercase text-accent mb-6">
        Veranstaltungskalender
      </h3>
      <p class="text-gray-600 leading-relaxed mb-8">
        Wettbewerbe, Meetings und Zuchttermine.
      </p>
      <div class="flex flex-col sm:flex-row flex-wrap items-stretch sm:items-center gap-3 sm:gap-4">
        {showCta && (
          <a href="/events" class="inline-flex items-center justify-center gap-2 min-h-[48px] px-6 py-3 bg-gray-900 text-white text-sm font-semibold rounded-xl transition-all duration-200 hover:bg-accent hover:shadow-lg hover:shadow-accent/20 hover:-translate-y-0.5 sm:px-8 sm:py-3.5 group btn-glow">
            Zur Events & Kalender-Seite
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        )}
        <a href="#kontakt" class="inline-flex items-center justify-center gap-2 min-h-[48px] px-6 py-3 border border-black/10 bg-white text-gray-800 text-sm font-semibold rounded-xl transition-all duration-200 hover:bg-gray-50 hover:border-black/20 hover:-translate-y-0.5 sm:px-8 sm:py-3.5 group">
          Kalender anfragen
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </article>

  </div>
</section>

<script>
  function initCountdown() {
    const targetDate = new Date('2026-04-12T09:00:00+02:00');
    const daysEl = document.querySelector('[data-countdown-days]');
    const hoursEl = document.querySelector('[data-countdown-hours]');
    const minutesEl = document.querySelector('[data-countdown-minutes]');
    if (!daysEl || !hoursEl || !minutesEl) return;

    function update() {
      const now = new Date();
      const diff = targetDate.getTime() - now.getTime();
      if (diff <= 0) {
        daysEl!.textContent = '0';
        hoursEl!.textContent = '0';
        minutesEl!.textContent = '0';
        return;
      }
      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      daysEl!.textContent = String(days);
      hoursEl!.textContent = String(hours);
      minutesEl!.textContent = String(minutes);
    }
    update();
    setInterval(update, 60000);
  }
  initCountdown();
  document.addEventListener('astro:page-load', initCountdown);
</script>

<style>
  .countdown-banner {
    padding: 28px 24px;
    background: white;
    border: 1px solid rgba(0,0,0,0.04);
    border-radius: 20px;
    text-align: center;
  }
  @media (min-width: 640px) {
    .countdown-banner { padding: 36px 32px; }
  }

  .countdown-grid {
    display: flex;
    justify-content: center;
    gap: 24px;
  }
  @media (min-width: 640px) { .countdown-grid { gap: 40px; } }

  .countdown-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .countdown-number {
    font-size: 32px;
    font-weight: 700;
    color: #86172c;
    line-height: 1;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }
  @media (min-width: 640px) { .countdown-number { font-size: 44px; } }
  .countdown-label {
    font-size: 11px;
    font-weight: 600;
    color: #71717a;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .event-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 24px;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.04);
    border-radius: 16px;
    text-decoration: none;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .event-card {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 20px;
      padding: 24px;
    }
  }
  @media (min-width: 1024px) { .event-card { gap: 24px; padding: 28px; } }

  .event-card:hover {
    border-color: rgba(134, 23, 44, 0.12);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .event-indicator {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 48px;
    background: #86172c;
    border-radius: 0 4px 4px 0;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .event-card:hover .event-indicator { opacity: 1; }

  .event-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 72px;
    width: fit-content;
    padding: 12px 8px;
    background: rgba(0, 0, 0, 0.02);
    border-radius: 12px;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  @media (min-width: 640px) { .event-date { min-width: 80px; padding: 14px 10px; } }
  @media (min-width: 1024px) { .event-date { min-width: 88px; padding: 16px 12px; } }
  .event-card:hover .event-date { background: rgba(134, 23, 44, 0.06); }

  .event-day { font-size: 28px; font-weight: 700; line-height: 1; color: #18181b; margin-bottom: 4px; }
  @media (min-width: 640px) { .event-day { font-size: 32px; } }
  @media (min-width: 1024px) { .event-day { font-size: 36px; } }

  .event-month { font-size: 10px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: #71717a; margin-bottom: 2px; }
  @media (min-width: 640px) { .event-month { font-size: 11px; } }
  .event-year { font-size: 10px; font-weight: 500; color: #a1a1aa; }

  .event-content { flex: 1; min-width: 0; overflow: hidden; }
  .event-title {
    font-size: 16px; font-weight: 600; color: #18181b; margin-bottom: 6px; line-height: 1.3;
    transition: color 0.2s ease;
    overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  }
  @media (min-width: 640px) { .event-title { font-size: 17px; -webkit-line-clamp: 1; } }
  @media (min-width: 1024px) { .event-title { font-size: 18px; } }
  .event-card:hover .event-title { color: #86172c; }

  .event-meta { display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap; font-size: 13px; color: #71717a; line-height: 1.5; }
  @media (min-width: 640px) { .event-meta { font-size: 14px; gap: 8px; } }
  .event-location { font-weight: 500; color: #52525b; }
  .event-separator { color: #d4d4d8; }
  .event-description { overflow: hidden; text-overflow: ellipsis; }
  @media (min-width: 640px) { .event-description { white-space: nowrap; } }

  .event-arrow {
    flex-shrink: 0; display: flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; color: #d4d4d8; transition: all 0.2s ease; align-self: flex-end;
  }
  @media (min-width: 640px) { .event-arrow { width: 36px; height: 36px; align-self: center; } }
  .event-card:hover .event-arrow { color: #86172c; transform: translateX(4px); }

  @media (max-width: 374px) {
    .event-card { padding: 16px; gap: 12px; }
    .event-date { min-width: 64px; padding: 10px 6px; }
    .event-day { font-size: 24px; }
    .event-month { font-size: 9px; }
    .event-year { font-size: 9px; }
    .event-title { font-size: 15px; }
    .event-meta { font-size: 12px; gap: 4px; }
    .event-arrow { width: 28px; height: 28px; }
  }

  @media (min-width: 1280px) {
    .event-card { padding: 32px; gap: 28px; }
    .event-date { min-width: 96px; padding: 18px 14px; }
    .event-day { font-size: 40px; }
    .event-title { font-size: 19px; }
    .event-meta { font-size: 15px; }
    .event-arrow { width: 40px; height: 40px; }
  }
</style>
