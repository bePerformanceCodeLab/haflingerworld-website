---
import { Image } from 'astro:assets';
import Squircle from './Squircle.astro';
import logoImage from '@/images/logo.svg';

const currentYear = new Date().getFullYear();

const navItems = [
  { href: '/haflinger', label: 'Haflinger' },
  { href: '/zucht', label: 'Zucht' },
  { href: '/netzwerk', label: 'Netzwerk' },
  { href: '/hwzsv', label: 'HWZSV' },
  { href: '/news', label: 'News' },
  { href: '/events', label: 'Events & Kalender' },
];

const legalItems = [
  { href: '/impressum', label: 'Impressum' },
  { href: '/datenschutz', label: 'Datenschutz' },
  { href: '/datenschutz#cookie', label: 'Cookie-Einstellungen' },
];

const contactCards = [
  {
    href: 'mailto:office@haflinger-world.com',
    icon: 'mail',
    label: 'E-Mail',
    value: 'office@haflinger-world.com',
  },
  {
    href: 'tel:+390471063970',
    icon: 'phone',
    label: 'Telefon',
    value: '+39 0471 063 970',
  },
  {
    href: 'https://maps.google.com/?q=Galvanistraße+38,+39100+Bozen,+Italy',
    icon: 'location',
    label: 'Adresse',
    value: 'Galvanistraße 38, 39100 Bozen',
    target: '_blank',
  },
  {
    href: 'https://www.facebook.com/HWZSV',
    icon: 'facebook',
    label: 'Facebook',
    value: 'facebook.com/HWZSV',
    target: '_blank',
  },
];
---

<footer id="kontakt" class="bg-gray-900 text-gray-400 border-t border-white/10 scroll-mt-24">
  <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
    
    <!-- Kontakt & Geschäftsstelle -->
    <div class="pt-16 sm:pt-20 lg:pt-24 pb-12 sm:pb-16 lg:pb-20 border-b border-white/10">
      <header class="text-center mb-10 sm:mb-12 lg:mb-14">
        <span class="block text-[11px] font-semibold tracking-[0.12em] uppercase text-accent/90 mb-2">
          Kontakt & Geschäftsstelle
        </span>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-semibold text-white tracking-tight mb-3">
          Wir sind gerne für Sie da
        </h2>
        <p class="text-base sm:text-lg text-gray-400 max-w-2xl mx-auto">
          Haflinger Welt-Zucht- und Sportvereinigung
        </p>
      </header>

      <!-- Contact Cards Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 max-w-6xl mx-auto">
        {contactCards.map((card) => (
          <Squircle 
            as="a" 
            href={card.href} 
            class="footer-card" 
            cornerRadius={14}
            target={card.target}
            rel={card.target ? 'noopener noreferrer' : undefined}
          >
            <div class="footer-card-icon">
              {card.icon === 'mail' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                </svg>
              )}
              {card.icon === 'phone' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                </svg>
              )}
              {card.icon === 'location' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
              )}
              {card.icon === 'facebook' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3V2z"></path>
                </svg>
              )}
            </div>
            <div class="flex-1 min-w-0">
              <span class="block text-[10px] font-semibold tracking-wider uppercase text-gray-500 mb-1">
                {card.label}
              </span>
              <span class="block text-sm sm:text-[15px] font-medium text-white tracking-tight truncate">
                {card.value}
              </span>
            </div>
            <div class="footer-card-arrow">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17 17 7M7 7h10v10"></path>
              </svg>
            </div>
          </Squircle>
        ))}
      </div>
    </div>

    <!-- Newsletter Section -->
    <div class="py-12 sm:py-16 lg:py-20 border-b border-white/10">
      <div class="max-w-3xl mx-auto text-center">
        <h3 class="text-xl sm:text-2xl font-semibold text-white mb-3">
          Newsletter abonnieren
        </h3>
        <p class="text-base text-gray-400 mb-8">
          Bleiben Sie informiert über Neuigkeiten, Events und wichtige Termine.
        </p>
        
        <!-- Newsletter Form -->
        <form class="footer-newsletter-form" action="#" method="post">
          <div class="footer-newsletter-wrapper">
            <input 
              type="email" 
              name="email" 
              placeholder="Ihre E-Mail-Adresse" 
              required 
              class="footer-newsletter-input"
            />
            <button type="submit" class="footer-newsletter-button">
              <span>Anmelden</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </button>
          </div>
          <p class="footer-newsletter-hint">
            Mit der Anmeldung akzeptieren Sie unsere <a href="/datenschutz" class="footer-newsletter-link">Datenschutzerklärung</a>.
          </p>
        </form>
      </div>
    </div>

    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16 py-16 sm:py-20 lg:py-24">
      
      <!-- Brand Column -->
      <div class="space-y-6">
        <a href="/" class="inline-flex items-center group">
          <div class="w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center border border-white/10 group-hover:bg-white/10 transition-colors">
            <Image 
              src={logoImage} 
              alt="HWZSV" 
              class="w-7 h-7 object-contain brightness-0 invert opacity-80" 
              width={28}
              height={28}
            />
          </div>
        </a>
        <p class="text-sm leading-relaxed max-w-xs text-gray-500">
          Die internationale Plattform der Haflinger Welt-Zucht- und Sportvereinigung. Wir verbinden Tradition, Qualität und Zukunft.
        </p>
      </div>

      <!-- Navigation Column -->
      <div>
        <h3 class="text-sm font-bold text-white tracking-widest uppercase mb-6">
          Navigation
        </h3>
        <ul class="space-y-3 text-sm">
          {navItems.map((item) => (
            <li>
              <a 
                href={item.href} 
                class="footer-link"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal Column -->
      <div>
        <h3 class="text-sm font-bold text-white tracking-widest uppercase mb-6">
          Rechtliches
        </h3>
        <ul class="space-y-3 text-sm">
          {legalItems.map((item) => (
            <li>
              <a 
                href={item.href} 
                class="footer-link"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 pb-16 sm:pb-20 lg:pb-24 border-t border-white/5">
      <div class="footer-bottom-bar">
        <!-- Left: Made by be. -->
        <div class="footer-bottom-left">
          <a 
            href="https://be-performance.com" 
            target="_blank" 
            rel="noopener" 
            class="footer-bottom-link"
          >
            <span class="footer-be-dot" aria-hidden="true"></span> Made by be.
          </a>
        </div>

        <!-- Center: Nach oben -->
        <div class="footer-bottom-center">
          <a href="#top" class="footer-bottom-link">
            Nach oben
          </a>
        </div>

        <!-- Right: Copyright -->
        <p class="footer-bottom-copy text-xs text-gray-600">
          &copy; {currentYear} HWZSV. Alle Rechte vorbehalten.
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Footer Cards */
  .footer-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 18px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-decoration: none;
    color: inherit;
    min-height: 80px;
    --fallback-radius: 14px;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (min-width: 640px) {
    .footer-card {
      padding: 18px 20px;
      min-height: 88px;
    }
  }

  @media (min-width: 1024px) {
    .footer-card {
      padding: 20px 22px;
      min-height: 96px;
    }
  }

  .footer-card:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(134, 23, 44, 0.5);
    transform: translateY(-2px);
  }

  .footer-card-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 11px;
    color: rgba(255, 255, 255, 0.8);
    transition: all 0.2s ease;
  }

  @media (min-width: 640px) {
    .footer-card-icon {
      width: 44px;
      height: 44px;
    }
  }

  .footer-card:hover .footer-card-icon {
    background: rgba(134, 23, 44, 0.3);
    color: white;
  }

  .footer-card-arrow {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    color: rgba(255, 255, 255, 0.35);
    transition: all 0.2s ease;
  }

  .footer-card:hover .footer-card-arrow {
    color: #e88a9a;
    transform: translate(2px, -2px);
  }

  /* Newsletter Form */
  .footer-newsletter-form {
    max-width: 560px;
    margin: 0 auto;
  }

  .footer-newsletter-wrapper {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
  }

  @media (max-width: 639px) {
    .footer-newsletter-wrapper {
      flex-direction: column;
    }
  }

  .footer-newsletter-input {
    flex: 1;
    min-height: 48px;
    padding: 0 18px;
    font-size: 15px;
    color: white;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    transition: all 0.2s ease;
  }

  @media (min-width: 640px) {
    .footer-newsletter-input {
      min-height: 52px;
      padding: 0 20px;
    }
  }

  .footer-newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .footer-newsletter-input:focus {
    outline: none;
    border-color: #86172c;
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 0 0 3px rgba(134, 23, 44, 0.15);
  }

  .footer-newsletter-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 48px;
    padding: 0 24px;
    background: white;
    color: #18181b;
    font-size: 14px;
    font-weight: 600;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    white-space: nowrap;
  }

  @media (min-width: 640px) {
    .footer-newsletter-button {
      min-height: 52px;
      padding: 0 28px;
      font-size: 15px;
    }
  }

  .footer-newsletter-button:hover {
    background: #86172c;
    color: white;
    box-shadow: 0 4px 12px rgba(134, 23, 44, 0.3);
    transform: translateY(-1px);
  }

  .footer-newsletter-button:active {
    transform: translateY(0);
  }

  .footer-newsletter-hint {
    font-size: 12px;
    color: #71717a;
    line-height: 1.5;
  }

  @media (min-width: 640px) {
    .footer-newsletter-hint {
      font-size: 13px;
    }
  }

  .footer-newsletter-link {
    color: #86172c;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-newsletter-link:hover {
    color: #e88a9a;
    text-decoration: underline;
  }

  /* Footer Links */
  .footer-link {
    display: block;
    padding: 8px 0;
    color: inherit;
    text-decoration: none;
    transition: all 0.2s ease;
    border-radius: 4px;
  }

  .footer-link:hover {
    color: white;
    transform: translateX(4px);
  }

  .footer-bottom-bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .footer-bottom-bar {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 1rem;
    }
  }

  .footer-bottom-left {
    order: 1;
    flex: 1 1 100%;
    display: flex;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .footer-bottom-left {
      order: 0;
      flex: none;
      justify-content: flex-start;
    }
  }

  .footer-bottom-center {
    order: 0;
    flex: 1 1 100%;
    display: flex;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .footer-bottom-center {
      order: 0;
      flex: none;
      justify-content: center;
    }
  }

  .footer-bottom-copy {
    order: 2;
    flex: 1 1 100%;
    width: 100%;
    text-align: center;
  }

  @media (min-width: 640px) {
    .footer-bottom-copy {
      order: 0;
      flex: none;
      width: auto;
      text-align: right;
    }
  }

  .footer-bottom-link {
    font-size: 13px;
    color: #71717a;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-bottom-link:hover {
    color: white;
  }

  /* Online-Status-Punkt bei "Made by be." – pulsierendes Grün (links vom Text) */
  .footer-be-dot {
    display: inline-block;
    width: 0.5em;
    height: 0.5em;
    margin-right: 6px;
    vertical-align: 0.2em;
    border-radius: 9999px;
    background-color: #44d72d;
    box-shadow: 0 0 0 0 rgba(68, 215, 45, 0.7);
    animation: footer-be-dot-pulse 1.6s ease-out infinite;
  }

  @keyframes footer-be-dot-pulse {
    0% {
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(68, 215, 45, 0.7);
    }
    70% {
      transform: scale(1.2);
      box-shadow: 0 0 0 8px rgba(68, 215, 45, 0);
    }
    100% {
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(68, 215, 45, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-be-dot {
      animation: none;
      box-shadow: 0 0 0 0 rgba(68, 215, 45, 0.7);
    }
  }

  /* Made by be. – sichtbar, passend zum Footer-Design */
  /* Extra Small Devices */
  @media (max-width: 374px) {
    .footer-card {
      padding: 14px 16px;
      gap: 10px;
      min-height: 76px;
    }

    .footer-card-icon {
      width: 36px;
      height: 36px;
    }

    .footer-newsletter-button {
      width: 100%;
    }
  }
</style>